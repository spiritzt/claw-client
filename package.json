{
  "name": "claw-client",
  "version": "1.0.0",
  "description": "肯登攀-多账号抖音自动发布客户端",
  "main": "dist/main/index.js",
  "scripts": {
    "build": "tsc",
    "start": "npm run build && electron .",
    "dev": "tsc -w & electron .",
    "dev:reload": "tsc && electron . --enable-logging",
    "pack": "electron-builder --dir",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "clean": "rm -rf dist release"
  },
  "keywords": ["douyin", "auto-publish", "electron"],
  "author": "",
  "license": "MIT",
  "build": {
    "appId": "com.kindpo.client",
    "productName": "肯龙虾",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon/icon.ico",
      "artifactName": "肯龙虾-${version}-Setup.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "肯龙虾"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "artifactName": "肯龙虾-${version}.${ext}"
    },
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ]
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "typescript": "^6.0.3"
  }
}